<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:macro name="camera2" params="suffix parent xyz rpy visualize_model:=true">
    <link name="camera_link_${suffix}">
      <xacro:if value="${visualize_model}">
        <visual>
          <origin rpy="0 ${pi/2} ${pi}"/>
          <geometry>
            <mesh filename="package://simbot_gz/meshes/camera.stl" />
          </geometry>
          <material name="black">
            <color rgba="0 0 0 1" />
          </material>
        </visual>
        <collision>
          <origin xyz="0 0 0.01" rpy="0 0 0"/>
          <geometry>
            <box size="0.028 0.09 0.03"/>
          </geometry>
        </collision>
    </xacro:if>
      <inertial>
        <mass value="0.5" />
        <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005" />
      </inertial>
    </link>

    <link name="camera_optical_frame_${suffix}" />

    <joint name="camera_optical_joint_${suffix}" type="fixed">
      <parent link="camera_link_${suffix}" />
      <child link="camera_optical_frame_${suffix}" />
      <origin xyz="0.015 0 0.015" rpy="1.5708 0 1.5708"/>
    </joint>

    <joint name="camera_joint_${suffix}" type="fixed">
      <parent link="${parent}" />
      <child link="camera_link_${suffix}" />
      <origin xyz="${xyz}" rpy="${rpy}" />
      <axis xyz="0 0 1"/>
    </joint>

    <gazebo reference="camera_link_${suffix}">
      <sensor name="camera_${suffix}" type="camera">
        <gz_frame_id>camera_optical_frame_${suffix}</gz_frame_id>
        <pose>0.05 0 0 0 0 0</pose>
        <always_on>0</always_on>
        <update_rate>30</update_rate>
        <visualize>false</visualize>
        <topic>rgb_${suffix}</topic>
        <camera>
          <camera_info_topic>rgb_${suffix}/camera_info</camera_info_topic>
          <horizontal_fov>1.2</horizontal_fov>
          <image>
            <width>1280</width>
            <height>720</height>
	    <anti_aliasing>8</anti_aliasing>
          </image>
          <clip>
            <near>0.1</near>
            <far>10</far>
          </clip>
        </camera>
      </sensor>
    </gazebo>
  </xacro:macro>

  <!-- Macro for a moving camera with prismatic joint in z direction -->
  <xacro:macro name="moving_camera2" params="suffix parent xyz rpy visualize_model:=true lower:=-1.0 upper:=1.0 effort:=10 velocity:=1.0">
    <link name="camera_link_${suffix}">
      <xacro:if value="${visualize_model}">
        <visual>
          <origin rpy="0 0 3.1416"/>
          <geometry>
            <mesh filename="package://simbot_gz/meshes/camera.stl" />
          </geometry>
          <material name="black">
            <color rgba="0 0 0 1" />
          </material>
        </visual>
        <collision>
          <origin rpy="0 0 0"/>
          <geometry>
            <box size="0.05 0.05 0.03"/>
          </geometry>
        </collision>
      </xacro:if>
      <inertial>
        <mass value="0.1" />
        <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005" />
      </inertial>
      <gravity>false</gravity>
    </link>

    <joint name="camera_joint_${suffix}" type="prismatic">
      <parent link="${parent}" />
      <child link="camera_link_${suffix}" />
      <origin xyz="${xyz}" rpy="${rpy}" />
      <axis xyz="-1 0 0"/>
      <limit lower="${lower}" upper="${upper}" effort="${effort}" velocity="${velocity}"/>
      <dynamics damping="10.0" friction="10.0"/>
    </joint>

    <gazebo reference="camera_joint_${suffix}">
      <provideFeedback>true</provideFeedback>
    </gazebo>

    <gazebo reference="camera_link_${suffix}">
      <sensor name="camera_${suffix}" type="camera">
        <gz_frame_id>camera_link_${suffix}</gz_frame_id>
        <pose>0.05 0 0 0 0 0</pose>
        <always_on>0</always_on>
        <update_rate>30</update_rate>
        <visualize>false</visualize>
        <topic>rgb_${suffix}</topic>
        <camera>
          <camera_info_topic>rgb_${suffix}/camera_info</camera_info_topic>
          <horizontal_fov>1.2</horizontal_fov>
          <image>
            <width>1280</width>
            <height>720</height>
            <anti_aliasing>8</anti_aliasing>
          </image>
          <clip>
            <near>0.1</near>
            <far>10</far>
          </clip>
        </camera>
      </sensor>
    </gazebo>
  </xacro:macro>
</robot>

